DICODesgloseContactoSI.Sucursal,=DICODesgloseContactoSI.Debe,
DICODesgloseContactoSI.Debe,=DICODesgloseContactoSI.Haber,
DICODesgloseContactoSI.Haber,=Cont.ID,
Cont.ID,=Cont.Mov,
Cont.Mov,=Cont.MovID,
Cont.MovID,=Cont.FechaEmision,
Cont.FechaEmision,=Cont.FechaContable,
Cont.FechaContable,=Cont.Moneda,
Cont.Moneda,=Cont.Referencia,
Cont.Referencia,=Cont.Observaciones,
Cont.Observaciones,=Cont.Origen,
Cont.Origen,=Cont.OrigenID,
Cont.OrigenID,=Empresa.Nombre,
Empresa.Nombre,=Sucursal.Nombre
Sucursal.Nombre=FROM DICODesgloseContactoSI
FROM DICODesgloseContactoSI=LEFT OUTER JOIN Cont ON DICODesgloseContactoSI.ID<IGUAL>Cont.ID
LEFT OUTER JOIN Cont ON DICODesgloseContactoSI.ID<IGUAL>Cont.ID=LEFT OUTER JOIN Empresa ON DICODesgloseContactoSI.Empresa<IGUAL>Empresa.Empresa
LEFT OUTER JOIN Empresa ON DICODesgloseContactoSI.Empresa<IGUAL>Empresa.Empresa=LEFT OUTER JOIN Sucursal ON DICODesgloseContactoSI.Sucursal<IGUAL>Sucursal.Sucursal
LEFT OUTER JOIN Sucursal ON DICODesgloseContactoSI.Sucursal<IGUAL>Sucursal.Sucursal=(Fin)

